<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#000000">
<title>SECRET SESSIONS</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Orbitron:wght@400;700;900&display=swap');

  :root {
    --black: #000000;
    --black-2: #050505;
    --black-3: #0A0A0A;
    --black-4: #111111;
    --white: #FFFFFF;
    --white-dim: rgba(255, 255, 255, 0.7);
    --white-ghost: rgba(255, 255, 255, 0.08);
    --border: rgba(255, 255, 255, 0.2);
    --border-strong: rgba(255, 255, 255, 0.5);
    --neon-glow: 0 0 10px rgba(255,255,255,0.6), 0 0 20px rgba(255,255,255,0.4), 0 0 30px rgba(255,255,255,0.2);
    --neon-glow-btn: 0 0 15px rgba(255,255,255,0.4), 0 0 30px rgba(255,255,255,0.2);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* ─── GRAIN OVERLAY ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ─── CURSOR CUSTOM ─── */
  .cursor-dot {
    position: fixed;
    width: 6px; height: 6px;
    background: var(--white);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
    transition: opacity 0.3s;
    display: none;
    box-shadow: 0 0 10px var(--white);
  }
  .cursor-ring {
    position: fixed;
    width: 32px; height: 32px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.3s, height 0.3s, border-color 0.3s;
    display: none;
    box-shadow: inset 0 0 10px rgba(255,255,255,0.1), 0 0 10px rgba(255,255,255,0.1);
  }
  @media (pointer: fine) {
    .cursor-dot, .cursor-ring { display: block; }
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%   { transform: translateY(0px); }
    50%  { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  @keyframes floatSlow {
    0%   { transform: translateY(0px); }
    50%  { transform: translateY(-5px); }
    100% { transform: translateY(0px); }
  }

  @keyframes pulseGlow {
    0%   { text-shadow: 0 0 10px rgba(255,255,255,0.4); }
    100% { text-shadow: 0 0 20px rgba(255,255,255,0.8), 0 0 30px rgba(255,255,255,0.4); }
  }
  
  @keyframes pulseGlowBtn {
    0%   { box-shadow: 0 0 10px rgba(255,255,255,0.3); }
    100% { box-shadow: 0 0 25px rgba(255,255,255,0.7), 0 0 40px rgba(255,255,255,0.3); }
  }

  @keyframes scanner {
    0% { transform: rotate(45deg) translateY(-100%); }
    100% { transform: rotate(45deg) translateY(100%); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ─── HERO ─── */
  #hero {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255,255,255,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 80% at 20% 80%, rgba(255,255,255,0.04) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 80% 20%, rgba(255,255,255,0.03) 0%, transparent 60%),
      rgba(0, 0, 0, 0.65);
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(8px);
    transform: scale(1.05);
    opacity: 0.45;
    pointer-events: none;
  }

  .hero-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 80%);
    animation: floatSlow 8s ease-in-out infinite alternate;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 40%, rgba(0,0,0,0.95) 100%);
  }

  .hero-top-bar {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.8rem;
    opacity: 0;
    animation: fadeUp 1s 0.3s forwards;
    width: 100%;
    justify-content: center;
  }

  .hero-top-bar span {
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--white-dim);
    text-transform: uppercase;
  }

  .dot-sep { width: 3px; height: 3px; background: var(--white); border-radius: 50%; box-shadow: 0 0 5px var(--white); }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    margin-top: 3rem;
  }

  .logo-main {
    margin-bottom: 0;
    opacity: 0;
    animation: fadeUp 1.2s 0.5s forwards;
  }

  .logo-divider {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--white), transparent);
    margin: 2rem auto;
    opacity: 0;
    animation: fadeUp 1s 0.7s forwards;
    box-shadow: var(--neon-glow);
  }

  .event-details-hero {
    opacity: 0;
    animation: fadeUp 1s 0.9s forwards;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--white);
    text-transform: uppercase;
  }

  .event-details-hero span {
    color: var(--white);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-shadow: var(--neon-glow);
    animation: pulseGlow 2s infinite alternate;
  }

  .hero-cta {
    margin-top: 3rem;
    opacity: 0;
    animation: fadeUp 1s 1.1s forwards;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.1rem 2.5rem;
    background: transparent;
    border: 1px solid var(--white);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    border-radius: 50px;
    box-shadow: var(--neon-glow-btn);
    animation: pulseGlowBtn 3s infinite alternate;
    transition: all 0.4s;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--white);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
    border-radius: 50px;
  }

  .btn-primary:hover::before { transform: translateX(0); }
  .btn-primary:hover { 
    color: var(--black); 
    box-shadow: 0 0 30px rgba(255,255,255,0.8);
  }
  .btn-primary span { position: relative; z-index: 1; }
  .btn-arrow { font-size: 0.9rem; position: relative; z-index: 1; transition: transform 0.3s; }
  .btn-primary:hover .btn-arrow { transform: translateX(4px); }

  /* ─── SHARED TITLES (Sans Thin Italic) ─── */
  .section-title, .access-title, .vip-banner-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 100;
    font-style: italic;
    letter-spacing: 0.05em;
    color: var(--white);
    text-transform: lowercase;
    text-shadow: var(--neon-glow);
    animation: pulseGlow 4s infinite alternate;
  }

  .section-title {
    font-size: clamp(2.5rem, 10vw, 5rem);
    text-align: center;
    line-height: 0.9;
    margin-bottom: 3rem;
  }

  /* ─── LINEUP SECTION ─── */
  #lineup {
    padding: 6rem 1.5rem;
    position: relative;
    z-index: 2;
    text-align: center;
    background: rgba(5, 5, 5, 0.65);
  }

  .section-label {
    text-align: center;
    font-size: 0.55rem;
    letter-spacing: 0.5em;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .lineup-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  .artist-name {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 6vw, 4rem);
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    position: relative;
    transition: color 0.4s, transform 0.4s;
    height: clamp(3rem, 8vw, 5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    white-space: nowrap;
    text-shadow: 0 0 10px rgba(255,255,255,0.2);
  }

  .artist-name:hover {
    transform: scale(1.05);
    text-shadow: var(--neon-glow);
  }

  /* ─── ACCESS TYPES SECTION ─── */
  #access-types {
    padding: 6rem 1.5rem;
    position: relative;
    z-index: 2;
    background: rgba(0, 0, 0, 0.65);
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .access-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .access-card {
    background: var(--black-3);
    border: 1px solid var(--border);
    padding: 2.5rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s, border-color 0.4s, box-shadow 0.4s;
    border-radius: 20px;
    animation: float 6s ease-in-out infinite;
  }
  
  .access-card:nth-child(2) { animation-delay: 2s; }
  .access-card:nth-child(3) { animation-delay: 4s; }

  .access-card:hover {
    transform: translateY(-10px);
    border-color: var(--white);
    box-shadow: 0 10px 30px rgba(255,255,255,0.2);
  }

  .access-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--white), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .access-card:hover::before { opacity: 1; }

  .access-title {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .access-price {
    font-size: 2.2rem;
    color: var(--white);
    font-weight: 700;
    margin-bottom: 1.5rem;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 0.05em;
    text-shadow: var(--neon-glow);
  }

  .access-card-img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    opacity: 0.35;
    transition: opacity 0.4s, filter 0.4s, transform 0.4s;
    filter: grayscale(100%) contrast(1.2);
  }

  .access-card:hover .access-card-img {
    opacity: 0.95;
    filter: grayscale(0%) contrast(1.1);
    transform: scale(1.02);
  }

  .access-availability {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--white-dim);
    text-transform: uppercase;
    font-style: normal;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--border);
  }

  .vip-tables-banner {
    margin: 3rem auto 0;
    max-width: 900px;
    background: var(--black-4);
    border: 1px solid var(--border-strong);
    padding: 2rem;
    text-align: center;
    border-radius: 20px;
    box-shadow: 0 0 20px rgba(255,255,255,0.05);
    animation: float 7s ease-in-out infinite alternate;
    position: relative;
    overflow: hidden;
  }

  .vip-tables-banner::after {
    content: '';
    position: absolute;
    top: -50%; left: -50%; width: 200%; height: 200%;
    background: linear-gradient(transparent, rgba(255,255,255,0.05), transparent);
    transform: rotate(45deg);
    animation: scanner 4s infinite linear;
    pointer-events: none;
  }

  .vip-banner-title {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .vip-banner-desc {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: var(--white-dim);
    text-transform: uppercase;
  }

  /* ─── FORM SECTION ─── */
  #form-section {
    padding: 6rem 1.5rem;
    position: relative;
    z-index: 2;
    background: rgba(5, 5, 5, 0.65);
  }

  #form-section::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--white), transparent);
  }

  .form-container {
    max-width: 650px;
    margin: 0 auto;
  }

  .form-ticket {
    background: var(--black-3);
    border: 1px solid var(--border-strong);
    padding: 2.5rem 1.5rem;
    position: relative;
    border-radius: 24px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    animation: float 8s ease-in-out infinite alternate-reverse;
  }

  .form-ticket::before {
    content: 'BOARDING PASS';
    position: absolute;
    top: -0.8rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    color: var(--black);
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 0.4em;
    padding: 0.3rem 1.5rem;
    white-space: nowrap;
    border-radius: 20px;
    box-shadow: var(--neon-glow);
  }

  .form-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .form-header-brand {
    font-family: 'Montserrat', sans-serif;
    font-weight: 100;
    font-style: italic;
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    color: var(--white);
    text-transform: lowercase;
    text-shadow: var(--neon-glow);
  }

  .form-header-meta {
    font-size: 0.5rem;
    letter-spacing: 0.3em;
    color: var(--white-dim);
    text-transform: uppercase;
    text-align: right;
    line-height: 1.8;
  }

  .form-group {
    margin-bottom: 1.5rem;
    position: relative;
  }

  .form-label {
    display: block;
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .form-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 300;
    padding: 0.6rem 0;
    outline: none;
    transition: border-color 0.3s;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
  }

  .form-input:focus { border-bottom-color: var(--white); }
  .form-input::placeholder { color: rgba(255,255,255,0.2); font-size: 0.75rem; }

  .form-input option {
    background: var(--black-3);
    color: var(--white);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 500px) {
    .form-row { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  }

  .form-divider {
    margin: 2rem 0;
    border: none;
    border-top: 1px dashed var(--border);
    position: relative;
  }

  .form-divider::after {
    content: attr(data-label);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--black-3);
    padding: 0 1rem;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--white);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Guest forms */
  #guests-container { margin-top: 1rem; }

  .guest-card {
    background: var(--black-4);
    border: 1px solid var(--border);
    border-left: 3px solid var(--white);
    padding: 1.5rem;
    margin-bottom: 1rem;
    position: relative;
    border-radius: 16px;
  }

  .guest-card-title {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 600;
    text-shadow: 0 0 10px rgba(255,255,255,0.3);
  }

  .form-submit-zone {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--border);
    text-align: center;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2rem;
    background: var(--white);
    color: var(--black);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
    border-radius: 50px;
    box-shadow: var(--neon-glow-btn);
    animation: pulseGlowBtn 3s infinite alternate;
  }

  .btn-submit::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--white-dim);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
    border-radius: 50px;
  }

  .btn-submit:hover::before { transform: translateX(0); }
  .btn-submit span { position: relative; z-index: 1; }

  .submit-note {
    margin-top: 1.5rem;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--white-dim);
  }

  /* ─── FOOTER ─── */
  footer {
    padding: 4rem 1.5rem;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 2;
    text-align: center;
    background: rgba(0, 0, 0, 0.75);
  }

  .footer-logo {
    font-family: 'Montserrat', sans-serif;
    font-weight: 100;
    font-style: italic;
    font-size: 1.8rem;
    letter-spacing: 0.1em;
    color: var(--white);
    margin-bottom: 0.5rem;
    text-transform: lowercase;
    text-shadow: var(--neon-glow);
  }

  .footer-tagline {
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    color: var(--white-dim);
    text-transform: uppercase;
  }

  .footer-copy {
    margin-top: 2.5rem;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
  }

  @media (min-width: 640px) {
    .form-ticket { padding: 3rem 2.5rem; }
  }

  /* ─── GLITCH TEXT EFFECT ─── */
  .glitch-text {
    position: relative;
    display: inline-block;
    color: var(--white);
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    background: transparent;
    color: var(--white);
    pointer-events: none;
    z-index: -1;
  }

  .glitch-text::before {
    left: -2px;
    text-shadow: -1px 0 rgba(255,255,255,0.8), 0 0 8px rgba(255,255,255,0.5);
    filter: blur(3px);
    animation: glitch-anim-1 2.5s infinite linear alternate-reverse;
    opacity: 0.8;
  }

  .glitch-text::after {
    left: 2px;
    text-shadow: 1px 0 rgba(255,255,255,0.8), 0 0 10px rgba(255,255,255,0.5);
    filter: blur(4px);
    animation: glitch-anim-2 3s infinite linear alternate-reverse;
    opacity: 0.8;
  }

  @keyframes glitch-anim-1 {
    0% { clip-path: inset(40% 0 61% 0); }
    10% { clip-path: inset(92% 0 1% 0); }
    20% { clip-path: inset(25% 0 58% 0); }
    30% { clip-path: inset(75% 0 10% 0); }
    40% { clip-path: inset(5% 0 80% 0); }
    50% { clip-path: inset(55% 0 30% 0); }
    60% { clip-path: inset(12% 0 78% 0); }
    70% { clip-path: inset(82% 0 5% 0); }
    80% { clip-path: inset(35% 0 50% 0); }
    90% { clip-path: inset(62% 0 28% 0); }
    100% { clip-path: inset(18% 0 72% 0); }
  }

  @keyframes glitch-anim-2 {
    0% { clip-path: inset(22% 0 70% 0); }
    10% { clip-path: inset(67% 0 25% 0); }
    20% { clip-path: inset(5% 0 88% 0); }
    30% { clip-path: inset(80% 0 5% 0); }
    40% { clip-path: inset(42% 0 45% 0); }
    50% { clip-path: inset(15% 0 72% 0); }
    60% { clip-path: inset(70% 0 18% 0); }
    70% { clip-path: inset(30% 0 58% 0); }
    80% { clip-path: inset(88% 0 2% 0); }
    90% { clip-path: inset(55% 0 35% 0); }
    100% { clip-path: inset(10% 0 80% 0); }
  }

  /* ─── PARTICLES CANVAS ─── */
  #particles-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
    opacity: 0.65;
  }

  /* ─── TICKET SELECT BUTTONS ─── */
  .btn-select-tier {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.8rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border-radius: 30px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .btn-select-tier span {
    position: relative;
    z-index: 2;
  }

  /* Diagonal Laser Shine Sweep */
  .btn-select-tier::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transform: skewX(-25deg);
    transition: none;
    z-index: 1;
  }

  .btn-select-tier:hover::before {
    animation: shine-sweep 1.2s infinite ease-in-out;
  }

  @keyframes shine-sweep {
    0% { left: -100%; }
    100% { left: 200%; }
  }

  .btn-select-tier:hover {
    border-color: var(--white);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.4), inset 0 0 10px rgba(255, 255, 255, 0.2);
    transform: translateY(-2px) scale(1.03);
    text-shadow: 0 0 5px rgba(255, 255, 255, 0.5);
  }

  /* Continuous gradient border flow */
  .btn-select-tier::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 30px;
    padding: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0.1), rgba(255,255,255,0.8), rgba(255,255,255,0.1));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    background-size: 200% auto;
    animation: gradient-flow 3s linear infinite;
    opacity: 0.5;
    transition: opacity 0.3s;
    z-index: 0;
  }

  .btn-select-tier:hover::after {
    opacity: 1;
    animation: gradient-flow 1.5s linear infinite;
  }

  @keyframes gradient-flow {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }
</style>
</head>
<body>

<!-- Custom cursor (desktop) -->
<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- ══════════════════════════════
     HERO
══════════════════════════════ -->
<section id="hero">
  <div class="hero-bg"></div>
  <video class="hero-video" autoplay loop muted playsinline>
    <source src="COMING SOON SECRET SESSIONS.mp4" type="video/mp4">
  </video>
  <div class="hero-lines"></div>
  <div class="hero-vignette"></div>

  <div class="hero-top-bar">
    <span>Capacidad: 300 Personas</span>
    <div class="dot-sep"></div>
    <span>Exclusive Access</span>
  </div>

  <div class="hero-content">
    <h1 class="logo-main" style="margin-bottom: 0;">
      <img src="Logo secretsessions.png" alt="Secret Sessions" style="max-width: 100%; height: auto; max-height: 250px; display: block; margin: 0 auto; filter: drop-shadow(0 0 20px rgba(255,255,255,0.2));">
      <span style="display: none;">Secret Sessions</span>
    </h1>

    <div class="logo-divider"></div>

    <div class="event-details-hero">
      <div><span>27 DE JUNIO 2026</span></div>
      <div>9:00 PM</div>
      <div style="color: var(--white-dim); margin-top: 0.5rem;">LUGAR: PENDIENTE DE CONFIRMAR</div>
    </div>

    <div class="hero-cta">
      <a href="#form-section" class="btn-primary">
        <span>Solicitar Acceso</span>
        <span class="btn-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════
     LINEUP
══════════════════════════════ -->
<section id="lineup">
  <p class="section-label reveal">Artists</p>
  <h2 class="section-title reveal"><span class="glitch-text" data-text="lineup">lineup</span></h2>

  <div class="lineup-list reveal">
    <div class="artist-name">ADONAY AG</div>
    <div class="artist-name">ALEX MINOR</div>
    <div class="artist-name">Aapenas es viernes</div>
  </div>
</section>

<!-- ══════════════════════════════
     ACCESS TYPES
══════════════════════════════ -->
<section id="access-types">
  <p class="section-label reveal">Tickets</p>
  <h2 class="section-title reveal"><span class="glitch-text" data-text="accesos">accesos</span></h2>

  <div class="access-grid reveal">
    <div class="access-card">
      <img class="access-card-img" src="private_access.png" alt="Private Access">
      <div class="access-title"><span class="glitch-text" data-text="private access">private access</span></div>
      <div class="access-price">$350</div>
      <button class="btn-select-tier" onclick="selectTicketTier('Private Access')">
        <span>Seleccionar</span>
        <span>→</span>
      </button>
    </div>
    <div class="access-card">
      <img class="access-card-img" src="priority_access.png" alt="Priority Access">
      <div class="access-title"><span class="glitch-text" data-text="priority access">priority access</span></div>
      <div class="access-price">$450</div>
      <button class="btn-select-tier" onclick="selectTicketTier('Priority Access')">
        <span>Seleccionar</span>
        <span>→</span>
      </button>
    </div>
    <div class="access-card">
      <img class="access-card-img" src="final_access.png" alt="Final Access">
      <div class="access-title"><span class="glitch-text" data-text="final access">final access</span></div>
      <div class="access-price">$500</div>
      <button class="btn-select-tier" onclick="selectTicketTier('Final Access')">
        <span>Seleccionar</span>
        <span>→</span>
      </button>
    </div>
  </div>

  <div class="vip-tables-banner reveal">
    <div class="vip-banner-title"><span class="glitch-text" data-text="vip tables & cortesías">vip tables & cortesías</span></div>
    <div class="vip-banner-desc">VIP Tables: Reservación vía WhatsApp<br>Cortesías: Solo administradores autorizados</div>
  </div>
</section>

<!-- ══════════════════════════════
     FORM
══════════════════════════════ -->
<section id="form-section">
  <div class="form-container">
    <p class="section-label reveal">Solicitud</p>
    <h2 class="section-title reveal">
      <span class="glitch-text" data-text="boarding">boarding</span><br>
      <span class="glitch-text" data-text="pass">pass</span>
    </h2>

    <div class="form-ticket reveal" id="solicitudForm">
      <div class="form-header">
        <div class="form-header-brand">Secret Sessions™</div>
        <div class="form-header-meta">
          27 Junio 2026<br>
          Limited to 300 Guests
        </div>
      </div>

      <!-- MAIN PASSENGER -->
      <div class="form-group">
        <label class="form-label" for="nombre">Nombre Completo *</label>
        <input class="form-input" type="text" id="nombre" placeholder="Tu nombre completo" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="whatsapp">WhatsApp *</label>
          <input class="form-input" type="tel" id="whatsapp" placeholder="+52 55 0000 0000" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="correo">Correo *</label>
          <input class="form-input" type="email" id="correo" placeholder="tu@correo.com" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="ciudad">Ciudad *</label>
          <input class="form-input" type="text" id="ciudad" placeholder="Ciudad de residencia" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="instagram">Instagram (Opcional)</label>
          <input class="form-input" type="text" id="instagram" placeholder="@usuario">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="acceso">Tipo de Acceso *</label>
          <select class="form-input" id="acceso" required>
            <option value="" disabled selected>Seleccionar</option>
            <option value="Private Access">Private Access ($350)</option>
            <option value="Priority Access">Priority Access ($450)</option>
            <option value="Final Access">Final Access ($500)</option>
            <option value="VIP Tables">VIP Tables</option>
            <option value="Cortesía">Cortesía (Solo Admin)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="personas">Núm. de Personas *</label>
          <select class="form-input" id="personas" required>
            <option value="" disabled selected>Cantidad</option>
            <option value="1">1 persona</option>
            <option value="2">2 personas</option>
            <option value="3">3 personas</option>
            <option value="4">4 personas</option>
            <option value="5">5 personas</option>
            <option value="6">6 personas</option>
            <option value="7">7 personas</option>
            <option value="8">8 personas</option>
            <option value="9">9 personas</option>
            <option value="10">10 personas</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="comentarios">Comentarios</label>
        <input class="form-input" type="text" id="comentarios" placeholder="Opcional: detalles de reservación, dudas, etc.">
      </div>

      <!-- GUEST CARDS -->
      <div id="guests-wrapper" style="display: none;">
        <hr class="form-divider" data-label="Asistentes Adicionales">
        <div id="guests-container"></div>
      </div>

      <div class="form-submit-zone">
        <button class="btn-submit" onclick="submitForm()">
          <span>✦ Enviar Solicitud por WhatsApp</span>
        </button>
        <p class="submit-note">No se guardarán tus datos en ningún servidor.<br>Serás redirigido a WhatsApp para enviar el mensaje de confirmación.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════
     FOOTER
══════════════════════════════ -->
<footer>
  <div class="footer-logo">Secret Sessions™</div>
  <div class="footer-tagline">Cinematic Electronic Experience</div>
  <div class="footer-copy">© 2026 Secret Sessions · Todos los derechos reservados</div>
</footer>

<script>
  // ─── CURSOR ───
  const dot = document.getElementById('cursorDot');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  if (window.matchMedia("(pointer: fine)").matches) {
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      dot.style.left = mx + 'px';
      dot.style.top  = my + 'px';
    });

    function animateRing() {
      rx += (mx - rx) * 0.12;
      ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px';
      ring.style.top  = ry + 'px';
      requestAnimationFrame(animateRing);
    }
    animateRing();

    document.querySelectorAll('a, button, .btn-primary, .btn-submit, .access-card').forEach(el => {
      el.addEventListener('mouseenter', () => {
        ring.style.width = '56px';
        ring.style.height = '56px';
        ring.style.borderColor = 'rgba(255,255,255,0.7)';
      });
      el.addEventListener('mouseleave', () => {
        ring.style.width = '32px';
        ring.style.height = '32px';
        ring.style.borderColor = 'rgba(255,255,255,0.4)';
      });
    });
  }

  // ─── SCROLL REVEAL ───
  const reveals = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 80);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(r => obs.observe(r));

  // ─── GUEST FORMS DYNAMIC GENERATION ───
  const personasSelect = document.getElementById('personas');
  const guestsWrapper = document.getElementById('guests-wrapper');
  const guestsContainer = document.getElementById('guests-container');

  personasSelect.addEventListener('change', function() {
    const n = parseInt(this.value);
    guestsContainer.innerHTML = '';
    
    if (!isNaN(n) && n > 1) {
      guestsWrapper.style.display = 'block';
      const count = n - 1; // asistentes adicionales
      for (let i = 1; i <= count; i++) {
        const card = document.createElement('div');
        card.className = 'guest-card';
        card.innerHTML = `
          <div class="guest-card-title">Asistente ${i + 1}</div>
          <div class="form-group">
            <label class="form-label">Nombre Completo *</label>
            <input class="form-input guest-nombre" type="text" placeholder="Nombre del asistente" required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">WhatsApp *</label>
              <input class="form-input guest-whatsapp" type="tel" placeholder="WhatsApp del asistente" required>
            </div>
            <div class="form-group">
              <label class="form-label">Correo *</label>
              <input class="form-input guest-correo" type="email" placeholder="Correo del asistente" required>
            </div>
          </div>
        `;
        guestsContainer.appendChild(card);
      }
    } else {
      guestsWrapper.style.display = 'none';
    }
  });

  // ─── SUBMIT FORM TO WHATSAPP ───
  function submitForm() {
    const nombre    = document.getElementById('nombre').value.trim();
    const whatsapp  = document.getElementById('whatsapp').value.trim();
    const correo    = document.getElementById('correo').value.trim();
    const ciudad    = document.getElementById('ciudad').value.trim();
    const instagram = document.getElementById('instagram').value.trim();
    const acceso    = document.getElementById('acceso').value;
    const personas  = document.getElementById('personas').value;
    const comentarios = document.getElementById('comentarios').value.trim();

    if (!nombre || !whatsapp || !correo || !ciudad || !acceso || !personas) {
      alert('Por favor completa todos los campos obligatorios (*)');
      return;
    }

    let allGuestsValid = true;
    const guestNames = document.querySelectorAll('.guest-nombre');
    const guestWhatsapps = document.querySelectorAll('.guest-whatsapp');
    const guestCorreos = document.querySelectorAll('.guest-correo');

    for (let i = 0; i < guestNames.length; i++) {
      if (!guestNames[i].value.trim() || !guestWhatsapps[i].value.trim() || !guestCorreos[i].value.trim()) {
        allGuestsValid = false;
        break;
      }
    }

    if (!allGuestsValid) {
      alert('Por favor completa los datos de todos los asistentes adicionales (*)');
      return;
    }

    let msg = `SECRET SESSIONS — NUEVA SOLICITUD\n\n`;
    msg += `Comprador principal:\n`;
    msg += `Nombre: ${nombre}\n`;
    msg += `WhatsApp: ${whatsapp}\n`;
    msg += `Correo: ${correo}\n`;
    msg += `Ciudad: ${ciudad}\n`;
    msg += `Instagram: ${instagram || 'N/A'}\n\n`;

    msg += `Tipo de acceso: ${acceso}\n`;
    msg += `Número de personas: ${personas}\n`;

    if (guestNames.length > 0) {
      msg += `\nAsistentes:\n`;
      guestNames.forEach((el, i) => {
        const gNombre = el.value.trim();
        const gWA = guestWhatsapps[i].value.trim();
        const gCorreo = guestCorreos[i].value.trim();
        msg += `${i + 1}. ${gNombre} / ${gWA} / ${gCorreo}\n`;
      });
    }

    msg += `\nComentarios: ${comentarios || 'Ninguno'}`;

    const encoded = encodeURIComponent(msg);
    const waURL = `https://wa.me/525565412779?text=${encoded}`;

    window.open(waURL, '_blank');
  }

  // Parallax subtle lines
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const lines = document.querySelector('.hero-lines');
    if (lines) lines.style.transform = `translateY(${y * 0.15}px)`;
  });

  // ─── TIKTOK VIRAL FONT EFFECT (SANS -> CURSIVE -> DESGASTADA) ───
  const artistNames = document.querySelectorAll('.artist-name');
  
  const sansFonts = [
    "'Montserrat', sans-serif",
    "'Helvetica Neue', Helvetica, Arial, sans-serif",
    "Impact, sans-serif",
    "'Bebas Neue', sans-serif",
    "'Arial Black', sans-serif"
  ];
  
  const cursiveFonts = [
    "'Brush Script MT', cursive",
    "'Snell Roundhand', cursive",
    "'Apple Chancery', cursive",
    "'Bradley Hand', cursive"
  ];
  
  const desgastadaFonts = [
    "Chalkduster, fantasy",
    "Papyrus, fantasy",
    "'Courier New', monospace",
    "Trattatello, fantasy",
    "Luminari, fantasy"
  ];

  const fontPhases = [sansFonts, cursiveFonts, desgastadaFonts];
  let currentPhase = 0;

  setInterval(() => {
    const currentFonts = fontPhases[currentPhase];
    artistNames.forEach(artist => {
      // Seleccionar una fuente aleatoria de la fase actual
      const randomFont = currentFonts[Math.floor(Math.random() * currentFonts.length)];
      artist.style.fontFamily = randomFont;
      
      // Aplicar estilos según la fase
      if (currentPhase === 0) {
        // Fase Sans
        artist.style.fontStyle = 'normal';
        artist.style.opacity = '1';
        artist.style.textTransform = 'uppercase';
        artist.style.letterSpacing = '0.05em';
      } else if (currentPhase === 1) {
        // Fase Cursiva
        artist.style.fontStyle = 'italic';
        artist.style.opacity = '1';
        artist.style.textTransform = 'none'; // Las cursivas lucen mejor en caja mixta
        artist.style.letterSpacing = 'normal';
      } else {
        // Fase Desgastada
        artist.style.fontStyle = 'italic';
        artist.style.opacity = Math.random() > 0.5 ? '0.6' : '0.9'; // Efecto desgastado/corrupto
        artist.style.textTransform = 'uppercase';
        artist.style.letterSpacing = '0.1em';
      }
    });
    
    // Avanzar a la siguiente fase
    currentPhase = (currentPhase + 1) % fontPhases.length;
  }, 800);

  // ─── CANVAS PARTICLES (Antigravity Style) ───
  const canvas = document.createElement('canvas');
  canvas.id = 'particles-canvas';
  document.body.appendChild(canvas);

  const ctx = canvas.getContext('2d');
  let width = canvas.width = window.innerWidth;
  let height = canvas.height = window.innerHeight;

  const particles = [];
  const particleCount = Math.min(100, Math.floor((width * height) / 15000));
  const connectionDistance = 110;
  let mouse = { x: null, y: null };

  class Particle {
    constructor() {
      this.x = Math.random() * width;
      this.y = Math.random() * height;
      this.vx = (Math.random() - 0.5) * 0.7;
      this.vy = (Math.random() - 0.5) * 0.7;
      this.radius = Math.random() * 2 + 1;
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;

      if (this.x < 0 || this.x > width) this.vx *= -1;
      if (this.y < 0 || this.y > height) this.vy *= -1;

      // Mouse repel interaction
      if (mouse.x !== null && mouse.y !== null) {
        const dx = this.x - mouse.x;
        const dy = this.y - mouse.y;
        const dist = Math.hypot(dx, dy);
        if (dist < 130) {
          const force = (130 - dist) / 130;
          this.x += (dx / dist) * force * 1.2;
          this.y += (dy / dist) * force * 1.2;
        }
      }
    }

    draw() {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
      ctx.fill();
    }
  }

  function initParticles() {
    particles.length = 0;
    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle());
    }
  }

  function animateParticles() {
    ctx.clearRect(0, 0, width, height);

    particles.forEach(p => {
      p.update();
      p.draw();

      // Dynamic mouse connection line
      if (mouse.x !== null && mouse.y !== null) {
        const mDist = Math.hypot(p.x - mouse.x, p.y - mouse.y);
        if (mDist < 150) {
          const alpha = (1 - mDist / 150) * 0.35;
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }
    });

    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const p1 = particles[i];
        const p2 = particles[j];
        const dist = Math.hypot(p1.x - p2.x, p1.y - p2.y);

        if (dist < connectionDistance) {
          const alpha = (1 - dist / connectionDistance) * 0.18;
          ctx.beginPath();
          ctx.moveTo(p1.x, p1.y);
          ctx.lineTo(p2.x, p2.y);
          ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }

    requestAnimationFrame(animateParticles);
  }

  window.addEventListener('resize', () => {
    width = canvas.width = window.innerWidth;
    height = canvas.height = window.innerHeight;
    initParticles();
  });

  document.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  document.addEventListener('mouseleave', () => {
    mouse.x = null;
    mouse.y = null;
  });

  // ─── TICKET SELECTION & AUTOFOCUS ───
  function selectTicketTier(tierName) {
    const accesoSelect = document.getElementById('acceso');
    if (accesoSelect) {
      accesoSelect.value = tierName;
      accesoSelect.dispatchEvent(new Event('change'));
    }

    const formSection = document.getElementById('form-section');
    if (formSection) {
      formSection.scrollIntoView({ behavior: 'smooth' });
    }

    // Flash highlighting glow on form
    const ticketBox = document.getElementById('solicitudForm');
    if (ticketBox) {
      ticketBox.style.transition = 'all 0.5s ease';
      ticketBox.style.borderColor = 'var(--white)';
      ticketBox.style.boxShadow = '0 0 35px rgba(255, 255, 255, 0.4)';
      setTimeout(() => {
        ticketBox.style.borderColor = 'var(--border-strong)';
        ticketBox.style.boxShadow = '0 10px 40px rgba(0,0,0,0.5)';
      }, 1500);
    }
  }

  initParticles();
  animateParticles();
</script>
</body>
</html>
